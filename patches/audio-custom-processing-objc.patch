diff --git a/sdk/objc/native/src/objc_audio_buffer.mm b/sdk/objc/native/src/objc_audio_buffer.mm
new file mode 100644
index 0000000000..184ef30607
--- /dev/null
+++ b/sdk/objc/native/src/objc_audio_buffer.mm
@@ -0,0 +1,21 @@
+#import "objc_audio_buffer.h"
+
+#include "modules/audio_processing/audio_buffer.h"
+
+@implementation ObjCAudioBufferWrapper
+
+@synthesize nativeAudioBuffer = buffer_;
+
+-(size_t)channels {
+	return buffer_->num_channels();
+}
+
+-(size_t)frames {
+	return buffer_->num_frames();
+}
+
+-(float*)channelAtIndex:(size_t)index {
+	return buffer_->channels()[index];
+}
+
+@end
