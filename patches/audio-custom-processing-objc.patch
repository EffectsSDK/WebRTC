+ *  that can be found in the LICENSE file in the root of the source
+ *  tree. An additional intellectual property rights grant can be found
+ *  in the file PATENTS.  All contributing project authors may
+ *  be found in the AUTHORS file in the root of the source tree.
+ */
+
+#ifndef SDK_OBJC_NATIVE_SRC_OBJC_AUDIO_CUSTOM_PROCESSING_H_
+#define SDK_OBJC_NATIVE_SRC_OBJC_AUDIO_CUSTOM_PROCESSING_H_
+
+#include "api/audio/audio_processing.h"
+
+#import "base/RTCAudioCustomProcessing.h"
+
+@class ObjCAudioBufferWrapper;
+
+namespace webrtc {
+
+class ObjCAudioCustomProcessing : public webrtc::CustomProcessing
+{
+public:
+	explicit ObjCAudioCustomProcessing(
+		id<RTC_OBJC_TYPE(RTCAudioCustomProcessing)> processing
+	);
+	
+	void Initialize(int sample_rate_hz, int num_channels) override;
+	
+	void Process(AudioBuffer *audio) override;
+	
+	std::string ToString() const override;
+	
+private:
+	__weak id<RTC_OBJC_TYPE(RTCAudioCustomProcessing)> processing_;
+	RTC_OBJC_TYPE(ObjCAudioBufferWrapper)* wrapper_;
+};
+
+}
+
+#endif  // SDK_OBJC_NATIVE_SRC_OBJC_AUDIO_CUSTOM_PROCESSING_H_
+ 
diff --git a/sdk/objc/native/src/objc_audio_custom_processing.mm b/sdk/objc/native/src/objc_audio_custom_processing.mm
new file mode 100644
index 0000000000..59a98607aa
--- /dev/null
+++ b/sdk/objc/native/src/objc_audio_custom_processing.mm
@@ -0,0 +1,30 @@
+#include "objc_audio_custom_processing.h"
+
+#import "objc_audio_buffer.h"
+
+namespace webrtc {
+
+ObjCAudioCustomProcessing::ObjCAudioCustomProcessing(
+	id<RTC_OBJC_TYPE(RTCAudioCustomProcessing)> processing)
+	: processing_(processing)
+{ 
+	wrapper_ = [[RTC_OBJC_TYPE(ObjCAudioBufferWrapper) alloc] init];
+}
+
+void ObjCAudioCustomProcessing::Initialize(int sample_rate_hz, int num_channels)
+{
+	[processing_ setupWithSampleRateHz:sample_rate_hz channels:num_channels];
+}
+
+void ObjCAudioCustomProcessing::Process(AudioBuffer *audio)
+{
+	wrapper_.nativeAudioBuffer = audio;
+	[processing_ processAudioBufferView:wrapper_];
+}
+
+std::string ObjCAudioCustomProcessing::ToString() const
+{
+	return std::string();
+}
+
+}
